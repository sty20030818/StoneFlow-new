{
	"name": "stoneflow",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "tsc -b && vite build",
		"lint": "oxlint",
		"lint:fix": "oxlint --fix",
		"format": "oxfmt",
		"format:check": "oxfmt --check",
		"test": "vitest",
		"test:run": "vitest run",
		"test:coverage": "vitest run --coverage",
		"test:rust": "cargo test --manifest-path src-tauri/Cargo.toml --workspace",
		"check": "bun run lint && bun run format:check && bun run test:run && bun run test:rust",
		"preview": "vite preview",
		"tauri": "tauri",
		"tauri:dev": "tauri dev",
		"tauri:build": "tauri build"
	},
	"dependencies": {
		"@tauri-apps/api": "^2.10.1",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"cmdk": "^1.1.1",
		"lucide-react": "^1.8.0",
		"radix-ui": "^1.4.3",
		"react": "^19.2.5",
		"react-dom": "^19.2.5",
		"react-router-dom": "^7.14.1",
		"tailwind-merge": "^3.5.0",
		"zustand": "^5.0.12"
	},
	"devDependencies": {
		"@tailwindcss/vite": "^4.2.2",
		"@tauri-apps/cli": "^2.10.1",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@types/node": "^25.6.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.1",
		"@vitest/coverage-v8": "^4.1.4",
		"jsdom": "^29.0.2",
		"oxfmt": "^0.45.0",
		"oxlint": "^1.60.0",
		"tailwindcss": "^4.2.2",
		"tw-animate-css": "^1.4.0",
		"typescript": "~6.0.3",
		"vite": "^8.0.9",
		"vitest": "^4.1.4"
	}
}
